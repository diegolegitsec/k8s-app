# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit it.

# ── GitHub / GHCR ────────────────────────────────────────────────────────────
# Your GitHub username or org (owner of the ghcr.io packages).
GITHUB_OWNER=your-github-username

# Image tag to deploy. Use "latest" for the most recent CI build,
# or a full Git SHA (e.g. abc1234) to pin to a specific build.
IMAGE_TAG=latest

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
EKS_CLUSTER_NAME=k8s-app

# Node group settings used when creating the cluster.
NODE_TYPE=t3.medium
NODE_COUNT=2
NODE_MIN=1
NODE_MAX=3
