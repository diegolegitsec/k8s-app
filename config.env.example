# Copy this file to config.env and fill in your values.
# config.env is gitignored — never commit it.

# ── GitHub / GHCR ────────────────────────────────────────────────────────────
# Your GitHub username or org (owner of the ghcr.io packages).
GITHUB_OWNER=your-github-username

# Image tag to deploy. Use "latest" for the most recent CI build,
# or a full Git SHA (e.g. abc1234) to pin to a specific build.
IMAGE_TAG=latest

# ── Redis ─────────────────────────────────────────────────────────────────────
# Strong random password for Redis auth. Use only alphanumeric + - _ characters.
# Generate one with: openssl rand -hex 24
REDIS_PASSWORD=change-me-strong-random-password

# ── CORS ──────────────────────────────────────────────────────────────────────
# The origin allowed to call the backend API.
# For local: http://localhost
# For AWS: set to the NLB DNS name after first deploy, then redeploy.
ALLOWED_ORIGIN=http://localhost

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
EKS_CLUSTER_NAME=k8s-app

# Node group settings used when creating the cluster.
NODE_TYPE=t3.medium
NODE_COUNT=2
NODE_MIN=1
NODE_MAX=3
